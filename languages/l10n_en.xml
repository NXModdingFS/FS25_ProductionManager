    <!-- ============================================================ -->
    <!-- Production Manager - Settings Menu                           -->
    <!-- ============================================================ -->
    <text name="production_menu_section_title"               text="Productions Manager"/>
    <text name="production_menu_automanage"                  text="Auto-Management"/>
    <text name="production_menu_automanage_tooltip"          text="Automatically restart stopped productions when inputs are available and outputs are not full."/>
    <text name="production_menu_hide_inactive"               text="Hide Inactive"/>
    <text name="production_menu_hide_inactive_tooltip"       text="Hide production facilities that have no active recipes."/>
    <text name="production_menu_notify_smart_control"        text="Notify: Smart Control"/>
    <text name="production_menu_notify_smart_control_tooltip" text="Show notifications when productions are automatically started, stopped, or resumed."/>
    <text name="production_menu_notify_low_inputs"           text="Notify: Low Inputs"/>
    <text name="production_menu_notify_low_inputs_tooltip"   text="Show notifications when input fill levels are running low or are completely empty."/>
    <text name="production_menu_notify_high_outputs"         text="Notify: High Outputs"/>
    <text name="production_menu_notify_high_outputs_tooltip" text="Show notifications when output storage is nearly full."/>
    <text name="production_menu_low_input_threshold"         text="Low Input Threshold"/>
    <text name="production_menu_low_input_threshold_tooltip" text="Fill percentage below which an input is considered low."/>
    <text name="production_menu_high_output_threshold"       text="High Output Threshold"/>
    <text name="production_menu_high_output_threshold_tooltip" text="Fill percentage above which an output is considered full."/>
    <text name="production_menu_notification_duration"       text="Notification Duration"/>
    <text name="production_menu_notification_duration_tooltip" text="How long on-screen notifications are displayed."/>

    <!-- Setting option strings -->
    <text name="production_setting_automanage_on"      text="Enabled"/>
    <text name="production_setting_automanage_off"     text="Disabled"/>
    <text name="production_setting_hide_inactive_on"   text="Hidden"/>
    <text name="production_setting_hide_inactive_off"  text="Shown"/>
