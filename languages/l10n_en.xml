    <text name="production_setting_duration_8s"        text="8 Seconds"/>
    <text name="production_setting_duration_10s"       text="10 Seconds"/>

    <!-- ============================================================ -->
    <!-- Production Manager - Notifications                           -->
    <!-- ============================================================ -->
    <!-- %1=recipe name, %2=facility name -->
    <text name="production_notify_started"           text="%s at %s has started."/>
    <text name="production_notify_resumed"           text="%s at %s has resumed."/>
    <!-- %1=recipe name, %2=facility name, %3=reason -->
    <text name="production_notify_stopped"           text="%s at %s has stopped. Reason: %s"/>
    <!-- %1=recipe name, %2=facility name, %3=comma-separated input names -->
    <text name="production_notify_out_of_inputs"     text="%s at %s has run out of: %s"/>
    <text name="production_notify_inputs_restored"   text="%s at %s: inputs have been restocked."/>
    <text name="production_notify_low_inputs"        text="%s at %s: inputs are running low: %s"/>
    <text name="production_notify_high_outputs"      text="%s at %s: outputs are nearly full: %s"/>

    <!-- Reason strings -->
    <text name="production_notify_reason_output_full"    text="Output storage full"/>
    <text name="production_notify_reason_out_of_inputs"  text="Out of inputs"/>
    <text name="production_notify_reason_low_inputs"     text="Inputs running low"/>
    <text name="production_notify_reason_unknown"        text="Unknown"/>
    <!-- New: shown when AutoManager skips restart because of schedule -->
    <text name="production_notify_reason_scheduled"      text="Outside scheduled months"/>

    <!-- Location fallback strings -->
    <text name="production_notify_unknown_location"      text="Unknown Location"/>
    <text name="production_notify_production_facility"   text="Production Facility"/>

